{
  "Name": "Render Cloud PACS",
  "HttpServerEnabled": true,
  "DicomServerEnabled": true,
  "DicomAet": "ORTHANC",
  "DicomPort": 4242,
  "HttpPort": 8042,
  "RemoteAccessAllowed": true,
  "AuthenticationEnabled": false,
  "Plugins": ["/usr/share/orthanc/plugins", "/usr/local/share/orthanc/plugins"],
  "CorsOrigin": "*",
  "CorsAllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
  "CorsAllowedHeaders": ["Origin", "X-Requested-With", "Content-Type", "Accept", "Authorization", "dicom-transfer-role", "Cache-Control", "Pragma", "If-Modified-Since", "Dicom-Transfer-Syntax"]
}
